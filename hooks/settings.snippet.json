{
  "_comment": "Merge the 'hooks' key into your ~/.claude/settings.json. Each hook POSTs to the app's local server (port 8787). Short timeout and non-blocking errors: if the app is closed, the hook fails silently without slowing Claude Code down.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "http", "url": "http://127.0.0.1:8787/hooks/session-start", "timeout": 3 }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          { "type": "http", "url": "http://127.0.0.1:8787/hooks/session-end", "timeout": 3 }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "http", "url": "http://127.0.0.1:8787/hooks/user-prompt", "timeout": 3 }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "http", "url": "http://127.0.0.1:8787/hooks/pre-tool", "timeout": 3 }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "http", "url": "http://127.0.0.1:8787/hooks/post-tool", "timeout": 3 }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          { "type": "http", "url": "http://127.0.0.1:8787/hooks/notification/permission", "timeout": 3 }
        ]
      },
      {
        "matcher": "idle_prompt",
        "hooks": [
          { "type": "http", "url": "http://127.0.0.1:8787/hooks/notification/idle", "timeout": 3 }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "http", "url": "http://127.0.0.1:8787/hooks/stop", "timeout": 3 }
        ]
      }
    ]
  }
}
